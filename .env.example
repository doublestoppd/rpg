# API / worker environment. Validated at startup (apps/api/src/config/env.ts);
# the process refuses to start if configuration is invalid.

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://rpg:rpg@localhost:5432/rpg
LOG_LEVEL=info

# Comma-separated origins allowed on state-changing requests and WebSocket
# upgrades (CSRF defense in depth).
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Chat send rate limits: token-bucket burst + sustained per-minute refill,
# per account and per client IP.
# CHAT_RATE_LIMIT_BURST=5
# CHAT_RATE_LIMIT_PER_MINUTE=20
# CHAT_RATE_LIMIT_IP_BURST=10
# CHAT_RATE_LIMIT_IP_PER_MINUTE=60

# Visible chat-message retention in days (allowed range 7-365). Worker
# cleanup is best-effort; reported messages and audit records never expire.
# CHAT_RETENTION_DAYS=90
