# API / worker environment. Validated at startup (apps/api/src/config/env.ts);
# the process refuses to start if configuration is invalid.

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgresql://rpg:rpg@localhost:5432/rpg
LOG_LEVEL=info

# Comma-separated origins allowed on state-changing requests and WebSocket
# upgrades (CSRF defense in depth).
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Chat send rate limits: token-bucket burst + sustained per-minute refill,
# per account and per client IP.
# CHAT_RATE_LIMIT_BURST=5
# CHAT_RATE_LIMIT_PER_MINUTE=20
# CHAT_RATE_LIMIT_IP_BURST=10
# CHAT_RATE_LIMIT_IP_PER_MINUTE=60

# Visible chat-message retention in days (allowed range 7-365). Worker
# cleanup is best-effort; reported messages and audit records never expire.
# CHAT_RETENTION_DAYS=90

# Administrator recent-auth window (minutes) gating admin mutations.
# ADMIN_REAUTH_WINDOW_MINUTES=10
# Reauth attempts per minute per IP (a password check).
# ADMIN_REAUTH_RATE_LIMIT_MAX=10
# Must be "true" for `npm run admin:promote` to run in production.
# ADMIN_BOOTSTRAP_ENABLED=false

# --- Phase 18 production hardening ---
# Reverse-proxy trust: "true"/"false", a hop count, or a comma-separated
# subnet/IP list. Required behind a proxy so request.ip and secure cookies work.
# TRUST_PROXY=false
# Send HSTS only when TLS is terminated ahead of the app.
# ENABLE_HSTS=false
# Bearer token guarding GET /api/v1/metrics (unset = endpoint disabled).
# METRICS_TOKEN=
# Worker health probe port (0 disables).
# WORKER_HEALTH_PORT=0
# Retention windows (days) for the data-lifecycle cleanup job.
# SESSION_RETENTION_DAYS=30
# NOTIFICATION_RETENTION_DAYS=30
# Build/commit id surfaced in health diagnostics (never a secret).
# BUILD_VERSION=
