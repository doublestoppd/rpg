// Prisma schema — Fantasy Economy RPG.
//
// pg-boss creates and manages its own infrastructure tables in the `pgboss`
// schema at worker startup. Gameplay tables arrive with their owning phases
// (see /docs/adr).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Phase 2 — accounts and sessions
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  /// Normalized (trimmed, lowercased) and unique.
  email        String   @unique
  /// Argon2id hash; raw passwords are never stored or logged.
  passwordHash String
  displayName  String   @unique
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions  Session[]
  settings  UserSettings?
  character Character?
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hex of the raw cookie token. The raw token exists only in the
  /// Secure, HttpOnly, SameSite cookie — never in the database.
  tokenHash String @unique

  /// Per-session CSRF token, stored server-side and returned to the frontend;
  /// required as X-CSRF-Token on every state-changing request.
  csrfToken String

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

model UserSettings {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme     Theme    @default(SYSTEM)
  updatedAt DateTime @updatedAt
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

// ---------------------------------------------------------------------------
// Phase 3 — characters and progression
// ---------------------------------------------------------------------------

/// Data-driven class configuration; seeded, never hard-coded in services.
model CharacterClassDefinition {
  slug        String @id
  name        String @unique
  description String

  baseHp           Int
  baseMp           Int
  baseStamina      Int
  baseStrength     Int
  baseAgility      Int
  baseMagic        Int
  baseDefense      Int
  baseMagicDefense Int
  baseLuck         Int

  growthHp           Int
  growthMp           Int
  growthStrength     Int
  growthAgility      Int
  growthMagic        Int
  growthDefense      Int
  growthMagicDefense Int
  growthLuck         Int

  characters Character[]
}

/// Cumulative XP required to hold each level. Seeded for levels 1-20 and
/// validated monotonic; the level cap is the highest seeded level.
model LevelProgression {
  level        Int @id
  cumulativeXp Int
}

model Character {
  id String @id @default(uuid())

  /// One character per account, enforced by this unique constraint.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String @unique

  classSlug String
  class     CharacterClassDefinition @relation(fields: [classSlug], references: [slug])

  level Int @default(1)
  /// Total accumulated XP (cumulative, compared against LevelProgression).
  xp    Int @default(0)

  /// Gold belongs to the character, not the user account. BIGINT; mutated
  /// only through the currency service once it exists (Phase 7).
  gold BigInt

  /// Current HP/MP are stored; maxima and combat attributes are derived from
  /// class + level (+ equipment later) and never duplicated in tables.
  currentHp Int
  currentMp Int

  /// Stamina regenerates lazily by timestamp at a configured whole-unit rate:
  /// effective = min(max, stamina + floor(elapsed / interval)). The stored
  /// pair only changes when stamina is spent.
  stamina          Int
  staminaUpdatedAt DateTime @default(now())

  /// Characters always occupy one location unless actively traveling.
  /// Nullable only for lazy backfill of characters created before Phase 4;
  /// services resolve null to the starting location.
  currentLocationId String?
  currentLocation   Location? @relation(fields: [currentLocationId], references: [id])

  travelStates TravelState[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Phase 4 — world graph and local features
// ---------------------------------------------------------------------------

model Location {
  id     String @id @default(uuid())
  slug   String @unique
  name   String @unique
  /// Broad region grouping (player shops register to a region in Phase 9).
  region String

  description String
  /// Frontend static placeholder asset key; no binary assets in the API.
  artworkKey  String
  /// Safe locations allow marketplace browsing (Phase 9) and host no combat.
  isSafe      Boolean

  features    LocationFeature[]
  routesFrom  TravelRoute[]     @relation("RouteFrom")
  routesTo    TravelRoute[]     @relation("RouteTo")
  characters  Character[]
}

enum LocationFeatureType {
  INN
  NPC_SHOP
  MARKETPLACE
  GATHERING
  CRAFTING
  COMBAT
  QUEST
  MUSEUM
}

/// Typed local-feature registry: what a location offers comes from these
/// records (or validated seed data), never from frontend conditionals.
model LocationFeature {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  type        LocationFeatureType
  name        String
  description String
  sortOrder   Int                 @default(0)

  @@unique([locationId, type, name])
  @@index([locationId])
}

// ---------------------------------------------------------------------------
// Phase 5 — timed travel
// ---------------------------------------------------------------------------

enum TravelStatus {
  IN_PROGRESS
  COMPLETED
}

/// Server-authoritative timed travel. The completesAt timestamp is the
/// authority (ADR 0004): travel is logically complete the moment it passes,
/// and every location-dependent request lazily finalizes it. A migration adds
/// a partial unique index so a character can have at most one IN_PROGRESS row.
model TravelState {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  routeId String
  route   TravelRoute @relation(fields: [routeId], references: [id])

  originLocationId      String
  destinationLocationId String

  startedAt   DateTime     @default(now())
  completesAt DateTime
  status      TravelStatus @default(IN_PROGRESS)
  completedAt DateTime?

  /// Client-supplied start idempotency key; repeats return this state.
  idempotencyKey String

  @@unique([characterId, idempotencyKey])
  @@index([characterId, status])
}

/// Directed route record; bidirectional travel uses two records.
model TravelRoute {
  id String @id @default(uuid())

  fromLocationId String
  fromLocation   Location @relation("RouteFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)

  toLocationId String
  toLocation   Location @relation("RouteTo", fields: [toLocationId], references: [id], onDelete: Cascade)

  /// Base travel duration in whole seconds (timed travel starts in Phase 5).
  travelSeconds Int
  /// Gold cost; must remain zero until currency charging exists (Phase 8).
  goldCost      BigInt @default(0)

  travelStates TravelState[]

  @@unique([fromLocationId, toLocationId])
  @@index([fromLocationId])
}
