// Prisma schema — Fantasy Economy RPG.
//
// pg-boss creates and manages its own infrastructure tables in the `pgboss`
// schema at worker startup. Gameplay tables arrive with their owning phases
// (see /docs/adr).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Phase 2 — accounts and sessions
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  /// Normalized (trimmed, lowercased) and unique.
  email        String   @unique
  /// Argon2id hash; raw passwords are never stored or logged.
  passwordHash String
  displayName  String   @unique
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions  Session[]
  settings  UserSettings?
  character Character?

  adminAuditLogs        AdminAuditLog[]
  chatModerationActions ChatModerationAction[]
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hex of the raw cookie token. The raw token exists only in the
  /// Secure, HttpOnly, SameSite cookie — never in the database.
  tokenHash String @unique

  /// Per-session CSRF token, stored server-side and returned to the frontend;
  /// required as X-CSRF-Token on every state-changing request.
  csrfToken String

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime  @default(now())
  revokedAt  DateTime?

  /// Server-side recent-auth marker for administrator mutations (Phase 17):
  /// set by POST /admin/reauth on this session only, cleared by role/password
  /// changes. A short configurable window gates every admin mutation. No
  /// second long-lived bearer token is ever issued.
  adminReauthenticatedAt DateTime?

  @@index([userId])
}

model UserSettings {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme     Theme    @default(SYSTEM)
  updatedAt DateTime @updatedAt
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

// ---------------------------------------------------------------------------
// Phase 3 — characters and progression
// ---------------------------------------------------------------------------

/// Data-driven class configuration; seeded, never hard-coded in services.
model CharacterClassDefinition {
  slug        String @id
  name        String @unique
  description String

  baseHp           Int
  baseMp           Int
  baseStamina      Int
  baseStrength     Int
  baseAgility      Int
  baseMagic        Int
  baseDefense      Int
  baseMagicDefense Int
  baseLuck         Int

  growthHp           Int
  growthMp           Int
  growthStrength     Int
  growthAgility      Int
  growthMagic        Int
  growthDefense      Int
  growthMagicDefense Int
  growthLuck         Int

  characters Character[]
}

/// Cumulative XP required to hold each level. Seeded for levels 1-20 and
/// validated monotonic; the level cap is the highest seeded level.
model LevelProgression {
  level        Int @id
  cumulativeXp Int
}

model Character {
  id String @id @default(uuid())

  /// One character per account, enforced by this unique constraint.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name String @unique

  classSlug String
  class     CharacterClassDefinition @relation(fields: [classSlug], references: [slug])

  level Int @default(1)
  /// Total accumulated XP (cumulative, compared against LevelProgression).
  xp    Int @default(0)

  /// Gold belongs to the character via its CurrencyAccount (Phase 7); the
  /// balance is mutated only through the currency service.
  currencyAccount CurrencyAccount?

  /// Current HP/MP are stored; maxima and combat attributes are derived from
  /// class + level (+ equipment later) and never duplicated in tables.
  currentHp Int
  currentMp Int

  /// Stamina regenerates lazily by timestamp at a configured whole-unit rate:
  /// effective = min(max, stamina + floor(elapsed / interval)). The stored
  /// pair only changes when stamina is spent.
  stamina          Int
  staminaUpdatedAt DateTime @default(now())

  /// Characters always occupy one location unless actively traveling.
  /// Nullable only for lazy backfill of characters created before Phase 4;
  /// services resolve null to the starting location.
  currentLocationId String?
  currentLocation   Location? @relation(fields: [currentLocationId], references: [id])

  travelStates TravelState[]

  inventoryStacks      InventoryStack[]
  itemInstances        ItemInstance[]
  equipment            EquipmentAssignment[]
  capacityReservations InventoryCapacityReservation[]
  transfersFrom        ItemTransfer[]                 @relation("TransferFrom")
  transfersTo          ItemTransfer[]                 @relation("TransferTo")
  npcPurchases         NpcShopPurchase[]
  playerShop           PlayerShop?
  marketListings       MarketplaceListing[]           @relation("ListingSeller")
  marketPurchases      MarketplaceSale[]              @relation("SaleBuyer")
  deliveries           Delivery[]                     @relation("DeliveryBuyer")
  skills               CharacterSkill[]
  gatheringRuns        GatheringRun[]
  professions          CraftingProfessionProgress[]
  craftingRuns         CraftingRun[]
  combats              Combat[]
  characterQuests      CharacterQuest[]
  collectionDonations  CharacterCollectionDonation[]
  notifications        Notification[]
  chatMessages         ChatMessage[]                  @relation("ChatMessageAuthor")
  chatReadStates       ChatChannelReadState[]
  chatBlocksMade       ChatBlock[]                    @relation("ChatBlocksMade")
  chatBlocksReceived   ChatBlock[]                    @relation("ChatBlocksReceived")
  chatReportsMade      ChatReport[]                   @relation("ChatReportsMade")
  chatRestrictions     ChatRestriction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Phase 4 — world graph and local features
// ---------------------------------------------------------------------------

model Location {
  id     String @id @default(uuid())
  slug   String @unique
  name   String @unique
  /// Broad region grouping (player shops register to a region in Phase 9).
  region String

  description String
  /// Frontend static placeholder asset key; no binary assets in the API.
  artworkKey  String
  /// Safe locations allow marketplace browsing (Phase 9) and host no combat.
  isSafe      Boolean

  features    LocationFeature[]
  routesFrom  TravelRoute[]     @relation("RouteFrom")
  routesTo    TravelRoute[]     @relation("RouteTo")
  characters  Character[]
  priceModifiers RegionalPriceModifier[]
  npcShops       NpcShop[]
  gatheringActions GatheringActionDefinition[]
  craftingRecipes  CraftingRecipe[]
  encounters       EncounterDefinition[]
  collections      CollectionDefinition[]
  chatChannel      ChatChannel?
}

enum LocationFeatureType {
  INN
  NPC_SHOP
  MARKETPLACE
  GATHERING
  CRAFTING
  COMBAT
  QUEST
  MUSEUM
}

/// Typed local-feature registry: what a location offers comes from these
/// records (or validated seed data), never from frontend conditionals.
model LocationFeature {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  type        LocationFeatureType
  name        String
  description String
  sortOrder   Int                 @default(0)

  @@unique([locationId, type, name])
  @@index([locationId])
}

// ---------------------------------------------------------------------------
// Phase 8 — regional pricing and NPC shops
// ---------------------------------------------------------------------------

/// Per-location price modifier in basis points (10000 = base value), keyed by
/// item category. Defined for the whole region map; only locations with
/// implemented shops have active prices today.
model RegionalPriceModifier {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  category    ItemCategory
  modifierBps Int

  @@unique([locationId, category])
}

model NpcShop {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  /// Purchase markup in basis points applied after the regional modifier.
  markupBps   Int
  /// Future resale rate; validated strictly below markupBps so a guaranteed
  /// buy-at-NPC/sell-to-NPC loop is impossible.
  sellbackBps Int

  /// Weighted restock pool + slot count, validated by Zod at seed and load.
  poolConfig Json

  restockIntervalSeconds Int
  restockJitterSeconds   Int

  /// Optimistic concurrency for admin configuration edits (Phase 17): a PATCH
  /// must present the expected version; a stale write loses with HTTP 409.
  configVersion Int @default(0)

  /// Timestamp authority for lazy restocking; exact values never leave the API.
  nextRestockAt    DateTime  @default(now())
  lastRestockAt    DateTime?
  currentRestockId String?

  restocks  NpcShopRestock[]
  purchases NpcShopPurchase[]
}

/// One restock batch. Stock entries always belong to a batch; only the
/// shop's current batch is purchasable.
model NpcShopRestock {
  id String @id @default(uuid())

  shopId String
  shop   NpcShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  restockedAt DateTime @default(now())

  stockEntries NpcShopStockEntry[]
  purchases    NpcShopPurchase[]

  @@index([shopId, restockedAt])
}

model NpcShopStockEntry {
  id String @id @default(uuid())

  restockId String
  restock   NpcShopRestock @relation(fields: [restockId], references: [id], onDelete: Cascade)

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  quantityTotal     Int
  quantityRemaining Int

  /// Regional price at restock time (BIGINT Gold per unit).
  unitPrice BigInt

  /// Purchase limit per character, per stock entry, per restock.
  perCharacterLimit Int

  purchases NpcShopPurchase[]

  @@index([restockId])
}

model NpcShopPurchase {
  id String @id @default(uuid())

  shopId String
  shop   NpcShop @relation(fields: [shopId], references: [id])

  restockId String
  restock   NpcShopRestock @relation(fields: [restockId], references: [id])

  stockEntryId String
  stockEntry   NpcShopStockEntry @relation(fields: [stockEntryId], references: [id])

  characterId String
  character   Character @relation(fields: [characterId], references: [id])

  quantity   Int
  unitPrice  BigInt
  totalPrice BigInt

  idempotencyKey String
  createdAt      DateTime @default(now())

  @@unique([characterId, idempotencyKey])
  @@index([characterId, stockEntryId])
}

// ---------------------------------------------------------------------------
// Phase 9 — player shops, marketplace, regional delivery
// ---------------------------------------------------------------------------

/// One shop per character, registered to a region (not a precise location).
model PlayerShop {
  id String @id @default(uuid())

  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  name        String @unique
  description String
  region      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings MarketplaceListing[]
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELED
  EXPIRED
}

/// Whole-listing fixed-price sale. The listed asset is out of active
/// inventory while ACTIVE: stack quantity is held on the listing itself;
/// instances stay seller-owned with lockState LISTED. A capacity reservation
/// guarantees safe return on cancel/expiry. Expired listings are unavailable
/// the moment expiresAt passes, before any cleanup runs.
model MarketplaceListing {
  id String @id @default(uuid())

  shopId String
  shop   PlayerShop @relation(fields: [shopId], references: [id])

  sellerCharacterId String
  seller            Character @relation("ListingSeller", fields: [sellerCharacterId], references: [id])

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  /// Set for instance listings (quantity is then 1).
  itemInstanceId String?       @unique
  itemInstance   ItemInstance? @relation(fields: [itemInstanceId], references: [id])

  quantity Int
  /// Whole-listing asking price (BIGINT Gold).
  price    BigInt
  feePaid  BigInt

  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  expiresAt   DateTime
  finalizedAt DateTime?

  returnReservationId String?

  idempotencyKey String

  sale MarketplaceSale?

  @@unique([sellerCharacterId, idempotencyKey])
  @@index([status, expiresAt])
  @@index([itemDefinitionId, status])
  @@index([sellerCharacterId, status])
}

model MarketplaceSale {
  id String @id @default(uuid())

  listingId String             @unique
  listing   MarketplaceListing @relation(fields: [listingId], references: [id])

  buyerCharacterId String
  buyer            Character @relation("SaleBuyer", fields: [buyerCharacterId], references: [id])

  sellerCharacterId String
  itemDefinitionId  String
  quantity          Int

  grossPrice     BigInt
  tax            BigInt
  sellerProceeds BigInt
  shippingFee    BigInt

  remote Boolean

  idempotencyKey String
  createdAt      DateTime @default(now())

  delivery Delivery?

  @@unique([buyerCharacterId, idempotencyKey])
  @@index([itemDefinitionId, createdAt])
}

enum DeliveryStatus {
  IN_TRANSIT
  DELIVERED
}

/// Timed remote delivery. Ownership already belongs to the buyer; goods are
/// transit-locked (stack quantities in DeliveryLine, instances IN_TRANSIT).
/// A capacity reservation created at purchase converts into inventory
/// placement exactly once at completion.
model Delivery {
  id String @id @default(uuid())

  saleId String          @unique
  sale   MarketplaceSale @relation(fields: [saleId], references: [id])

  buyerCharacterId String
  buyer            Character @relation("DeliveryBuyer", fields: [buyerCharacterId], references: [id])

  status      DeliveryStatus @default(IN_TRANSIT)
  startedAt   DateTime       @default(now())
  arrivesAt   DateTime
  deliveredAt DateTime?

  capacityReservationId String

  lines DeliveryLine[]

  @@index([buyerCharacterId, status])
}

model DeliveryLine {
  id String @id @default(uuid())

  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  quantity       Int
  itemInstanceId String?

  @@index([deliveryId])
}

// ---------------------------------------------------------------------------
// Phase 10 — gathering skills and timed mining
// ---------------------------------------------------------------------------

enum SkillType {
  MINING
}

/// Per-character gathering skill progress. Level is derived from xp by the
/// skill progression table (never stored, so the two cannot disagree).
model CharacterSkill {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  skill SkillType
  xp    Int       @default(0)

  updatedAt DateTime @updatedAt

  @@unique([characterId, skill])
}

/// Data-driven gathering action (seeded, never hard-coded in services).
/// rewardTable is a Zod-validated weighted pool; one entry is drawn per run.
model GatheringActionDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  skill SkillType

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  /// Minimum skill level to start this action.
  levelRequirement Int
  staminaCost      Int
  durationSeconds  Int
  /// Skill XP awarded on completion.
  xpReward         Int

  rewardTable Json
  sortOrder   Int  @default(0)

  runs GatheringRun[]

  @@index([locationId])
}

enum GatheringRunStatus {
  IN_PROGRESS
  /// Work finished but the reward could not be placed (inventory full); the
  /// rolled reward is held on the run — never rerolled or discarded.
  REWARD_HELD
  COMPLETED
}

/// One timed gathering run. The authoritative reward is rolled with secure
/// server RNG at start and stored in `outcome`; it is server-private and is
/// never serialized into pending API responses. completesAt is the authority
/// (ADR 0004); a migration adds a partial unique index so a character has at
/// most one unfinished (non-COMPLETED) run.
model GatheringRun {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  actionId String
  action   GatheringActionDefinition @relation(fields: [actionId], references: [id])

  status GatheringRunStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  completesAt DateTime
  /// When the timed work was finalized (rewards granted or held).
  completedAt DateTime?
  /// When rewards actually entered the inventory (equals completedAt unless
  /// the run passed through REWARD_HELD).
  claimedAt   DateTime?

  /// Server-private rolled outcome: rewards + skill XP. Never exposed while
  /// the run is IN_PROGRESS.
  outcome Json

  /// Stamina charged once at start (recorded for auditability).
  staminaCost Int

  idempotencyKey String

  @@unique([characterId, idempotencyKey])
  @@index([characterId, status])
}

// ---------------------------------------------------------------------------
// Phase 11 — crafting professions and timed blacksmithing
// ---------------------------------------------------------------------------

enum ProfessionType {
  BLACKSMITHING
}

/// Per-character crafting profession progress. Level is derived from xp by
/// the shared profession progression (never stored).
model CraftingProfessionProgress {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  profession ProfessionType
  xp         Int            @default(0)

  updatedAt DateTime @updatedAt

  @@unique([characterId, profession])
}

/// Data-driven recipe (seeded, never hard-coded in services). Crafting is
/// deterministic: fixed inputs, fixed Gold cost, fixed output — no RNG and
/// no failure chance. `inputs` is a Zod-validated list of {itemSlug, quantity}.
model CraftingRecipe {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  profession ProfessionType

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  /// Minimum profession level to start this recipe.
  levelRequirement Int
  /// Forge fee in Gold, debited atomically at start (BIGINT).
  goldCost         BigInt
  durationSeconds  Int
  /// Profession XP awarded on completion.
  xpReward         Int

  inputs Json

  outputItemDefinitionId String
  outputItemDefinition   ItemDefinition @relation(fields: [outputItemDefinitionId], references: [id])
  outputQuantity         Int

  sortOrder Int @default(0)

  runs CraftingRun[]

  @@index([locationId])
}

enum CraftingRunStatus {
  IN_PROGRESS
  /// Work finished but the output could not be placed (inventory full); the
  /// pending output stays on the run — never rerolled or discarded.
  OUTPUT_HELD
  COMPLETED
}

/// One timed crafting run. Inputs and Gold are consumed atomically at start
/// inside the run-creation transaction; `output` snapshots what will be
/// granted so completion is exactly-once and immune to recipe edits.
/// completesAt is the authority (ADR 0004); a migration adds a partial
/// unique index so a character has at most one unfinished run.
model CraftingRun {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  recipeId String
  recipe   CraftingRecipe @relation(fields: [recipeId], references: [id])

  status CraftingRunStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  completesAt DateTime
  /// When the timed work was finalized (output granted or held).
  completedAt DateTime?
  /// When the output actually entered the inventory.
  claimedAt   DateTime?

  /// Snapshot of the pending output + profession XP, granted exactly once.
  output Json

  /// Gold debited at start (recorded for auditability).
  goldPaid BigInt

  idempotencyKey String

  @@unique([characterId, idempotencyKey])
  @@index([characterId, status])
}

// ---------------------------------------------------------------------------
// Phase 12 — classic initiative-gauge combat
// ---------------------------------------------------------------------------

/// Seeded enemy archetype. Stats mirror character attributes; `affinities`
/// maps element → damage-taken multiplier in basis points (15000 weak,
/// 10000 neutral, 5000 resistant, 0 immune). `aiConfig` is a Zod-validated
/// weighted action list; `rewardConfig` holds XP, a Gold range, and drops.
model EnemyDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  level        Int
  maxHp        Int
  maxMp        Int
  strength     Int
  agility      Int
  magic        Int
  defense      Int
  magicDefense Int
  luck         Int

  /// Attacks ignore the back-row melee penalty (flying/shooting foes).
  ranged Boolean @default(false)

  affinities   Json
  aiConfig     Json
  rewardConfig Json
}

enum EncounterKind {
  NORMAL
  ELITE
  BOSS
}

/// Seeded encounter at a combat location. `composition` lists enemy slugs
/// with rows; `unlockRequirements` optionally gates on character level and a
/// prior victory over another encounter (the boss gate).
model EncounterDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  kind     EncounterKind
  fleeable Boolean       @default(true)

  composition        Json
  /// Additional flee-chance modifier in basis points (signed).
  fleeModifierBps    Int   @default(0)
  unlockRequirements Json?

  sortOrder Int @default(0)

  combats Combat[]
}

enum CombatStatus {
  ACTIVE
  VICTORY
  DEFEAT
  FLED
}

/// A persisted combat instance. Fully server-authoritative: state advances
/// only through the command endpoint (optimistic `version` check, combat row
/// lock) — there is no permanent tick loop. The PRNG seed is server-secret
/// until completion; `rngCounter` makes every draw deterministic and
/// replayable for a persisted combat.
model Combat {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  encounterId String
  encounter   EncounterDefinition @relation(fields: [encounterId], references: [id])

  status  CombatStatus @default(ACTIVE)
  /// Incremented by every resolved command; commands carry expectedVersion.
  version Int          @default(0)

  /// Server-secret deterministic PRNG seed (hex); never exposed while ACTIVE.
  rngSeed    String
  rngCounter Int    @default(0)

  /// Append-only human-readable combat log.
  log Json

  /// Failed flee attempts so far (feeds the retry bonus).
  fleeAttempts Int @default(0)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  idempotencyKey String

  combatants  CombatantState[]
  rewardGrant CombatRewardGrant?

  @@unique([characterId, idempotencyKey])
  @@index([characterId, status])
}

enum CombatantKind {
  PLAYER
  ENEMY
}

enum CombatRow {
  FRONT
  BACK
}

/// One participant's persisted state. Attributes are snapshotted at combat
/// start (player: class + level + equipment). The initiative gauge is stored
/// in fixed-point thousandths (0..100000 == 0..100).
model CombatantState {
  id String @id @default(uuid())

  combatId String
  combat   Combat @relation(fields: [combatId], references: [id], onDelete: Cascade)

  kind CombatantKind
  /// Deterministic tie-break ordinal (lower wins the final tie).
  slot Int
  name String

  enemyDefinitionId String?

  row    CombatRow
  ranged Boolean   @default(false)

  currentHp Int
  currentMp Int
  /// Fixed-point gauge: 100000 = ready.
  gauge     Int @default(0)

  maxHp        Int
  maxMp        Int
  strength     Int
  agility      Int
  magic        Int
  defense      Int
  magicDefense Int
  luck         Int

  /// Element → damage-taken multiplier bps (players are all-neutral).
  affinities Json

  statusEffects CombatStatusEffect[]

  @@unique([combatId, slot])
  @@index([combatId])
}

/// An active status on a combatant. `magnitude` is status-specific (poison
/// damage per tick, blind accuracy penalty bps, slow/haste rate bps, guard
/// reduction bps, stun charges, armor-break defense reduction bps).
/// `remainingTurns` decrements after the affected combatant completes an
/// action (poison ticks then too); GUARD instead expires when the defender's
/// next command phase begins.
model CombatStatusEffect {
  id String @id @default(uuid())

  combatantId String
  combatant   CombatantState @relation(fields: [combatantId], references: [id], onDelete: Cascade)

  type           String
  magnitude      Int
  remainingTurns Int

  @@index([combatantId])
}

/// Exactly-once victory reward marker: created in the same transaction that
/// flips the combat to VICTORY (unique per combat), alongside XP, Gold, and
/// item grants.
model CombatRewardGrant {
  id String @id @default(uuid())

  combatId String @unique
  combat   Combat @relation(fields: [combatId], references: [id])

  characterId String

  xp   Int
  gold BigInt
  /// Granted drops [{itemSlug, quantity}] and any left behind for capacity.
  drops Json

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Phase 13 — quests and transactional domain events
// ---------------------------------------------------------------------------

enum QuestObjectiveType {
  TRAVEL_TO_LOCATION
  GATHER_ITEM
  CRAFT_RECIPE
  DEFEAT_ENEMY
  DONATE_ITEM
}

/// Seeded quest. Rewards are granted only through the manual claim
/// transaction: XP, Gold (BIGINT), and items ([{itemSlug, quantity}]).
model QuestDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  rewardXp    Int
  rewardGold  BigInt
  rewardItems Json

  sortOrder Int @default(0)

  objectives      QuestObjective[]
  characterQuests CharacterQuest[]
}

/// One typed objective. Progress comes exclusively from typed in-process
/// domain events emitted by verified actions (travel, gathering, crafting,
/// combat, donation) inside their own transactions — never from the client.
model QuestObjective {
  id String @id @default(uuid())

  questId String
  quest   QuestDefinition @relation(fields: [questId], references: [id], onDelete: Cascade)

  sortOrder     Int
  type          QuestObjectiveType
  /// What the event must match: a location, item, recipe, or enemy slug.
  targetSlug    String
  requiredCount Int
  description   String

  progress QuestProgress[]

  @@unique([questId, sortOrder])
}

enum CharacterQuestStatus {
  /// Reserved intermediate state (acceptance currently activates directly).
  ACCEPTED
  ACTIVE
  COMPLETED_UNCLAIMED
  CLAIMED
}

model CharacterQuest {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  questId String
  quest   QuestDefinition @relation(fields: [questId], references: [id])

  status CharacterQuestStatus @default(ACTIVE)

  acceptedAt  DateTime  @default(now())
  completedAt DateTime?
  claimedAt   DateTime?

  progress QuestProgress[]

  @@unique([characterId, questId])
  @@index([characterId, status])
}

model QuestProgress {
  id String @id @default(uuid())

  characterQuestId String
  characterQuest   CharacterQuest @relation(fields: [characterQuestId], references: [id], onDelete: Cascade)

  objectiveId String
  objective   QuestObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  currentCount Int       @default(0)
  completedAt  DateTime?

  @@unique([characterQuestId, objectiveId])
}

// ---------------------------------------------------------------------------
// Phase 14 — museum collection and item destruction
// ---------------------------------------------------------------------------

/// A seeded museum collection hosted at one location (Regional Artifacts at
/// the Crownfall City museum).
model CollectionDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  sortOrder Int @default(0)

  entries CollectionEntry[]
}

/// One eligible artifact in a collection. Only the FIRST donation of each
/// entry counts per character (enforced by CharacterCollectionDonation).
model CollectionEntry {
  id String @id @default(uuid())

  collectionId String
  collection   CollectionDefinition @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  /// Curator's note shown once donated.
  curatorNote String
  sortOrder   Int    @default(0)

  donations CharacterCollectionDonation[]

  @@unique([collectionId, itemDefinitionId])
}

/// A character's donation of one entry — at most one per entry, forever.
/// Normal gameplay cannot reverse a donation.
model CharacterCollectionDonation {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  collectionEntryId String
  collectionEntry   CollectionEntry @relation(fields: [collectionEntryId], references: [id])

  itemDefinitionId String
  /// Set when the donated asset was a tracked instance.
  itemInstanceId   String?

  donatedAt DateTime @default(now())

  @@unique([characterId, collectionEntryId])
  @@index([characterId])
}

/// Permanent record of destroyed goods (museum donations today; other
/// destruction sources may reference this later). Written in the same
/// transaction as the destruction itself.
model ItemDestruction {
  id String @id @default(uuid())

  characterId String

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  itemInstanceId String?
  quantity       Int

  reason String
  /// Reference to the causing record (e.g. "CharacterCollectionDonation"/id).
  refType String?
  refId   String?

  createdAt DateTime @default(now())

  @@index([characterId, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 15 — persistent notifications
// ---------------------------------------------------------------------------

/// A stored player notification — the source of truth (WebSockets only
/// nudge clients to refetch). Created inside the same transaction as the
/// causing domain event; `dedupeKey` (unique per character) makes creation
/// idempotent between lazy finalizers and worker jobs.
model Notification {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  /// Stable type (TRAVEL_COMPLETED, DELIVERY_COMPLETED, LISTING_SOLD,
  /// GATHERING_COMPLETED, CRAFTING_COMPLETED, QUEST_COMPLETED).
  type String

  /// Public display payload ({title, body}); never internal state.
  payload Json

  /// Domain-event key, e.g. "travel:<travelStateId>".
  dedupeKey String

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([characterId, dedupeKey])
  @@index([characterId, readAt])
  @@index([characterId, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 7 — currency ledger
// ---------------------------------------------------------------------------

/// The authoritative Gold balance for a character. BIGINT; every change is
/// applied by the currency service inside a transaction together with exactly
/// one immutable CurrencyTransaction row.
model CurrencyAccount {
  id String @id @default(uuid())

  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  balance BigInt

  updatedAt DateTime @updatedAt

  transactions CurrencyTransaction[]
}

/// Immutable ledger entry: signed amount (credit positive, debit negative)
/// plus the balance before and after. Idempotency keys are unique per account
/// and operation namespace.
model CurrencyTransaction {
  id String @id @default(uuid())

  accountId String
  account   CurrencyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt

  /// Stable operation type (STARTING_GRANT, INN_REST, NPC_PURCHASE, …).
  type String

  /// Related entity reference (e.g. "TravelState"/id, "NpcShopPurchase"/id).
  relatedType String?
  relatedId   String?

  operationNamespace String
  idempotencyKey     String?

  createdAt DateTime @default(now())

  @@unique([accountId, operationNamespace, idempotencyKey])
  @@index([accountId, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 6 — items, inventory, capacity, transfers, equipment
// ---------------------------------------------------------------------------

enum ItemCategory {
  RESOURCE
  CONSUMABLE
  EQUIPMENT
  CRAFTING_COMPONENT
  COLLECTIBLE
  QUEST_ITEM
  SPECIALTY
}

enum EquipmentSlot {
  MAIN_HAND
  OFF_HAND
  HEAD
  BODY
  HANDS
  LEGS
  FEET
  ACCESSORY_1
  ACCESSORY_2
}

model ItemDefinition {
  id   String @id @default(uuid())
  slug String @unique
  name String @unique

  description String
  category    ItemCategory

  /// Stackable commodities live in InventoryStack; non-stackable items are
  /// tracked as ItemInstance rows with individual ownership history.
  stackable        Boolean
  maxStackQuantity Int     @default(1)

  /// For EQUIPMENT: the slot family this item fits. ACCESSORY_1 here means
  /// "fits either accessory slot" (the assignment picks the concrete slot).
  equipmentSlot    EquipmentSlot?
  levelRequirement Int            @default(1)

  bonusStrength     Int @default(0)
  bonusAgility      Int @default(0)
  bonusMagic        Int @default(0)
  bonusDefense      Int @default(0)
  bonusMagicDefense Int @default(0)
  bonusLuck         Int @default(0)
  bonusMaxHp        Int @default(0)
  bonusMaxMp        Int @default(0)

  /// Consumable effects (0 = none).
  hpRestore      Int     @default(0)
  mpRestore      Int     @default(0)
  usableInCombat Boolean @default(false)

  /// Reference value in Gold for NPC pricing (BIGINT).
  baseValue BigInt @default(0)

  /// Optimistic concurrency for admin edits of safe presentation/economic
  /// fields (Phase 17). Structural fields (slug, stackability, slot, effect
  /// schema) are never mutable and would reinterpret existing assets.
  configVersion Int @default(0)

  stacks    InventoryStack[]
  instances ItemInstance[]
  transfers ItemTransfer[]
  npcStockEntries   NpcShopStockEntry[]
  marketListings    MarketplaceListing[]
  deliveryLines     DeliveryLine[]
  craftingOutputs   CraftingRecipe[]
  collectionEntries CollectionEntry[]
  destructions      ItemDestruction[]
}

/// One row per character + stackable item definition.
model InventoryStack {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  quantity Int

  updatedAt DateTime @updatedAt

  @@unique([characterId, itemDefinitionId])
  @@index([characterId])
}

enum ItemInstanceLock {
  NONE
  LISTED
  IN_TRANSIT
}

/// A uniquely tracked item (equipment or otherwise stateful).
model ItemInstance {
  id String @id @default(uuid())

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  ownerCharacterId String?
  ownerCharacter   Character? @relation(fields: [ownerCharacterId], references: [id])

  /// Locked (listed / in-transit) instances are outside active inventory and
  /// cannot be equipped, consumed, discarded, or transferred.
  lockState   ItemInstanceLock @default(NONE)
  destroyedAt DateTime?

  createdAt DateTime @default(now())

  equipment EquipmentAssignment?
  transfers ItemTransfer[]
  listing   MarketplaceListing?

  @@index([ownerCharacterId])
}

model EquipmentAssignment {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  slot EquipmentSlot

  itemInstanceId String       @unique
  itemInstance   ItemInstance @relation(fields: [itemInstanceId], references: [id])

  @@unique([characterId, slot])
}

/// Holds a destination slot for assets that will return or arrive later
/// (expired listings, deliveries, pending rewards). Active while releasedAt
/// is null; counts toward used capacity.
model InventoryCapacityReservation {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  slots  Int    @default(1)
  reason String
  /// Free-form reference to the owning record (e.g. listing/delivery id).
  refId  String?

  createdAt  DateTime  @default(now())
  releasedAt DateTime?

  @@index([characterId, releasedAt])
}

/// Movement record. Stack commodities use aggregate rows (quantity N,
/// itemInstanceId null); unique instances get one row per transfer, giving
/// full ownership history. from/to null means the world (grant/consume).
model ItemTransfer {
  id String @id @default(uuid())

  itemDefinitionId String
  itemDefinition   ItemDefinition @relation(fields: [itemDefinitionId], references: [id])

  itemInstanceId String?
  itemInstance   ItemInstance? @relation(fields: [itemInstanceId], references: [id])

  quantity Int

  fromCharacterId String?
  fromCharacter   Character? @relation("TransferFrom", fields: [fromCharacterId], references: [id])
  toCharacterId   String?
  toCharacter     Character? @relation("TransferTo", fields: [toCharacterId], references: [id])

  reason    String
  createdAt DateTime @default(now())

  @@index([itemInstanceId])
  @@index([fromCharacterId])
  @@index([toCharacterId])
}

// ---------------------------------------------------------------------------
// Phase 5 — timed travel
// ---------------------------------------------------------------------------

enum TravelStatus {
  IN_PROGRESS
  COMPLETED
}

/// Server-authoritative timed travel. The completesAt timestamp is the
/// authority (ADR 0004): travel is logically complete the moment it passes,
/// and every location-dependent request lazily finalizes it. A migration adds
/// a partial unique index so a character can have at most one IN_PROGRESS row.
model TravelState {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  routeId String
  route   TravelRoute @relation(fields: [routeId], references: [id])

  originLocationId      String
  destinationLocationId String

  startedAt   DateTime     @default(now())
  completesAt DateTime
  status      TravelStatus @default(IN_PROGRESS)
  completedAt DateTime?

  /// Client-supplied start idempotency key; repeats return this state.
  idempotencyKey String

  @@unique([characterId, idempotencyKey])
  @@index([characterId, status])
}

/// Directed route record; bidirectional travel uses two records.
model TravelRoute {
  id String @id @default(uuid())

  fromLocationId String
  fromLocation   Location @relation("RouteFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)

  toLocationId String
  toLocation   Location @relation("RouteTo", fields: [toLocationId], references: [id], onDelete: Cascade)

  /// Base travel duration in whole seconds (timed travel starts in Phase 5).
  travelSeconds Int
  /// Gold cost; must remain zero until currency charging exists (Phase 8).
  goldCost      BigInt @default(0)

  travelStates TravelState[]

  @@unique([fromLocationId, toLocationId])
  @@index([fromLocationId])
}

// ---------------------------------------------------------------------------
// Phase 16 — player chat, safety, and real-time delivery
// ---------------------------------------------------------------------------

enum ChatChannelKind {
  GLOBAL
  LOCATION
}

/// Seeded chat channels: exactly one GLOBAL channel and one LOCATION channel
/// per world location. A migration adds a CHECK constraint (GLOBAL has no
/// location, LOCATION has exactly one) and a partial unique index enforcing
/// the single global channel; unique locationId enforces one per location.
model ChatChannel {
  id   String          @id @default(uuid())
  slug String          @unique
  kind ChatChannelKind

  locationId String?   @unique
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  messages   ChatMessage[]
  readStates ChatChannelReadState[]
}

enum ChatMessageStatus {
  VISIBLE
}

/// One immutable plain-text chat message. No edit or user-delete path exists;
/// retention cleanup may remove old unreported rows, and later administrative
/// redaction must preserve a tombstone (ordering and IDs survive).
model ChatMessage {
  id String @id @default(uuid())

  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Restrict)

  authorCharacterId String
  author            Character @relation("ChatMessageAuthor", fields: [authorCharacterId], references: [id], onDelete: Restrict)

  /// Validated, normalized plain text (1-500 code points, <= 2000 UTF-8
  /// bytes, no disallowed control characters). Stored exactly as validated.
  body String

  status ChatMessageStatus @default(VISIBLE)

  /// Client-supplied send idempotency key, unique per author: replays return
  /// this message and concurrent same-key sends create exactly one row.
  idempotencyKey String

  createdAt DateTime @default(now())

  /// Administrative redaction (Phase 17): a redacted row keeps its id, author,
  /// channel, and ordering as a tombstone; only the player-visible body is
  /// replaced. Report snapshots and audit evidence are preserved. There is no
  /// hard-delete path for a message that has been redacted or reported.
  redactedAt      DateTime?
  redactedByUserId String?
  redactionReason String?

  reports ChatReport[]

  @@unique([authorCharacterId, idempotencyKey])
  /// Stable cursor pagination and unread counting order by (createdAt, id).
  @@index([channelId, createdAt, id])
}

/// Per-character read position in a channel. Advances only forward (to a real
/// message in the channel); the stored (createdAt, id) pair keeps comparisons
/// stable without a foreign key, so retention cleanup never breaks it.
model ChatChannelReadState {
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  /// Deliberately not a foreign key: the referenced message may be cleaned up
  /// later; the copied (createdAt, id) ordering pair remains valid forever.
  lastReadMessageId        String
  lastReadMessageCreatedAt DateTime

  updatedAt DateTime @updatedAt

  @@id([characterId, channelId])
}

/// Unilateral block: the blocker no longer sees the blocked author's messages
/// or live invalidations. Never visible to (and never alters data of) the
/// blocked character. A migration adds a CHECK preventing self-blocks.
model ChatBlock {
  blockerCharacterId String
  blocker            Character @relation("ChatBlocksMade", fields: [blockerCharacterId], references: [id], onDelete: Cascade)

  blockedCharacterId String
  blocked            Character @relation("ChatBlocksReceived", fields: [blockedCharacterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([blockerCharacterId, blockedCharacterId])
}

enum ChatReportReason {
  HARASSMENT
  SPAM
  ABUSIVE_LANGUAGE
  CHEATING_OR_EXPLOITS
  OTHER
}

enum ChatReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

/// One report per reporter and message, with an immutable evidence snapshot
/// taken at report time — the evidence survives message retention cleanup
/// (the Restrict relation makes reported messages undeletable) and any later
/// redaction. The reporter is never revealed to the reported player.
model ChatReport {
  id String @id @default(uuid())

  reporterCharacterId String
  reporter            Character @relation("ChatReportsMade", fields: [reporterCharacterId], references: [id], onDelete: Restrict)

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Restrict)

  reason ChatReportReason
  /// Optional bounded free-text details from the reporter.
  details String?

  /// Immutable snapshots at report time (deliberately not foreign keys).
  snapshotBody              String
  snapshotAuthorCharacterId String
  snapshotChannelId         String

  status    ChatReportStatus @default(OPEN)
  createdAt DateTime         @default(now())

  /// Administrative resolution (Phase 17). The immutable evidence snapshot
  /// above is preserved regardless of resolution.
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionReason String?

  @@unique([reporterCharacterId, messageId])
  @@index([status, createdAt])
}

enum ChatRestrictionStatus {
  ACTIVE
  REVOKED
}

/// A temporary or indefinite chat-send restriction. Timestamp-authoritative:
/// an ACTIVE row past its expiresAt is lazily treated as inactive — no worker
/// is required. No public API creates these in Phase 16 (the send service
/// enforces them; administration arrives in Phase 17).
model ChatRestriction {
  id String @id @default(uuid())

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Restrict)

  status   ChatRestrictionStatus @default(ACTIVE)
  startsAt DateTime              @default(now())
  /// Null means indefinite.
  expiresAt DateTime?

  reason String

  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([characterId, status, expiresAt])
}

// ---------------------------------------------------------------------------
// Phase 17 — administration, moderation, auditable economy operations
// ---------------------------------------------------------------------------

/// Append-only authoritative business audit for administrator mutations. This
/// is a distinct domain from the technical `authoritative mutation` log and
/// from CurrencyTransaction/ItemTransfer/ItemDestruction/MarketplaceSale/
/// ChatReport — it never replaces them. A database trigger rejects UPDATE and
/// DELETE so rows are immutable. Every successful admin mutation writes one row
/// in the SAME transaction as the domain change. before/after JSON is a
/// secret-free allowlist, never a full Prisma record.
model AdminAuditLog {
  id String @id @default(uuid())

  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  /// Snapshot of the acting session id at write time (the session may later be
  /// revoked; the audit reference remains).
  actorSessionId String

  /// Dotted action namespace, e.g. "currency.adjust", "chat.redact".
  actionNamespace String
  targetType      String
  targetId        String

  /// Mandatory bounded human reason for the action.
  reason String

  requestId      String
  idempotencyKey String

  /// Outcome marker (SUCCESS for committed mutations).
  outcome String

  /// Allowlisted, secret-free before/after snapshots.
  beforeJson Json?
  afterJson  Json?

  createdAt DateTime @default(now())

  @@unique([actorUserId, actionNamespace, idempotencyKey])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actionNamespace, createdAt])
  @@index([createdAt])
}

enum ChatModerationActionType {
  REDACT_MESSAGE
  APPLY_RESTRICTION
  REVOKE_RESTRICTION
  RESOLVE_REPORT
}

/// Explicit moderation-action record linking a redaction/restriction/
/// revocation/report-resolution to its actor, subject, reason, and related
/// message/report/restriction. Deliberately a first-class domain record rather
/// than only a generic audit line.
model ChatModerationAction {
  id String @id @default(uuid())

  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  action ChatModerationActionType

  subjectCharacterId String?
  messageId          String?
  reportId           String?
  restrictionId      String?

  reason String

  createdAt DateTime @default(now())

  @@index([subjectCharacterId, createdAt])
  @@index([action, createdAt])
}

// ---------------------------------------------------------------------------
// Phase 19 — versioned game content and publishing lifecycle
// ---------------------------------------------------------------------------

enum ContentReleaseStatus {
  DRAFT
  VALIDATING
  PUBLISHED
  RETIRED
}

/// A versioned bundle of game-content definitions moving through a publishing
/// lifecycle. The live gameplay tables remain the runtime source of truth; this
/// platform records immutable published revisions, enables validation, export/
/// import, and safe evolution WITHOUT changing gameplay. Release 1 is a
/// snapshot of the originally seeded content.
model ContentRelease {
  id      String               @id @default(uuid())
  /// Monotonic release number; unique across the platform.
  version Int                  @unique
  status  ContentReleaseStatus @default(DRAFT)

  /// Human label + mandatory reason recorded at publish/retire time.
  title  String
  notes  String?

  createdAt   DateTime  @default(now())
  publishedAt DateTime?
  retiredAt   DateTime?

  definitions ContentDefinition[]

  @@index([status, version])
}

enum ContentType {
  ITEM
  LOCATION
  TRAVEL_ROUTE
  LOCATION_FEATURE
  REGIONAL_PRICE_MODIFIER
  NPC_SHOP
  GATHERING_ACTION
  CRAFTING_RECIPE
  ENEMY
  ENCOUNTER
  QUEST
  COLLECTION
  CHARACTER_CLASS
  LEVEL_PROGRESSION
}

/// One content definition within a release: a stable key, a revision number,
/// a canonical JSON payload (references expressed by stable key, never DB id),
/// and a checksum. Rows belonging to a PUBLISHED release are immutable —
/// enforced by a database trigger so a published revision can never change.
model ContentDefinition {
  id String @id @default(uuid())

  releaseId String
  release   ContentRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  contentType ContentType
  /// Stable key, unique per (release, type). Never a database id.
  stableKey   String
  /// Revision number for this key across the platform (informational).
  revision    Int         @default(1)

  /// Canonical, deterministic payload. References use stable keys.
  payload  Json
  /// SHA-256 of the canonical payload, for integrity + change detection.
  checksum String

  createdAt DateTime @default(now())

  @@unique([releaseId, contentType, stableKey])
  @@index([contentType, stableKey])
}
